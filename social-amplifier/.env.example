# Server
PORT=3000
HOST=localhost
BASE_URL=http://localhost:3000

# Database (SQLite path relative to project root)
DATABASE_PATH=./data/amplifier.db

# Session secret (change in production)
SESSION_SECRET=change-me-in-production

# Facebook / Meta
# https://developers.facebook.com/apps/
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:3000/api/auth/facebook/callback

# Instagram (uses Facebook Graph API)
# Same app as Facebook — requires Instagram Basic Display or Instagram Graph API permissions
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/auth/instagram/callback

# X (Twitter)
# https://developer.x.com/en/portal/dashboard
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:3000/api/auth/x/callback

# TikTok
# https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3000/api/auth/tiktok/callback
